NODE_ENV=production
PORT=3002

# Database (PostgreSQL)
# Use 127.0.0.1 when Postgres runs on the same server.
DB_DIALECT=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dating_app
DB_USER=dating_user
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_LOGGING=false
# DB_SSL=false

# Auth (required, >= 32 chars)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# WeChat OAuth (required for mini program login)
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_secret

# Optional: used when generating absolute URLs
API_DOMAIN=https://api.halfdestiny.com

# Optional: Aliyun OSS (media storage)
OSS_REGION=oss-cn-hongkong
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_CDN_DOMAIN=
OSS_PRIVATE_BUCKET=
OSS_PRIVATE_REGION=
INTERNAL_SERVICE_TOKEN=

# Optional: CORS (comma-separated)
ALLOWED_ORIGINS=https://servicewechat.com

# Optional: EaseMob / 环信 IM
EASEMOB_HOST=https://a1.easemob.com
EASEMOB_ORG_NAME=your_org_name
EASEMOB_APP_NAME=your_app_name
EASEMOB_CLIENT_ID=your_client_id
EASEMOB_CLIENT_SECRET=your_client_secret
